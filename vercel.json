{
  "buildCommand": "bash build_files.sh",
  "framework": "django",
  "env": {
    "DEBUG": "False",
    "PYTHONUNBUFFERED": "1"
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "staticfiles_build/static/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "hospital_management/wsgi.py",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS", "HEAD"]
    }
  ],
  "functions": {
    "hospital_management/wsgi.py": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "**"
    }
  }
}
