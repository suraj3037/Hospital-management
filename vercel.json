{
    "buildCommand": "bash build_files.sh",
    "framework": "django",
    "env": {
        "DEBUG": "False",
        "PYTHONUNBUFFERED": "1"
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "hospital_management/wsgi.py"
        }
    ],
    "functions": {
        "hospital_management/wsgi.py": {
            "memory": 1024,
            "maxDuration": 30,
            "includeFiles": "**"
        }
    }
}